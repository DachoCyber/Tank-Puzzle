{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Build SFML project",
            "command": "C:/mingw32/bin/g++.exe",
            "args": [
                "-std=c++17",
                "-DSFML_STATIC",
                "-g",

                "${workspaceFolder}/src/*.cpp",
                "-o",
                "${workspaceFolder}/bin/output.exe",

                "-I", "${workspaceFolder}/SFML-2.6.2-windows-gcc-13.1.0-mingw-32-bit(1)/SFML-2.6.2/include",
                "-L", "${workspaceFolder}/SFML-2.6.2-windows-gcc-13.1.0-mingw-32-bit(1)/SFML-2.6.2/lib",

                "-lsfml-graphics-s",
                "-lsfml-window-s",
                "-lsfml-system-s",
                "-lsfml-audio-s",
                "-lsfml-network-s",
                
                "-lopengl32",
                "-lfreetype",
                "-lwinmm",
                "-lgdi32",
                "-lopenal32",
                "-lflac",
                "-lvorbisenc",
                "-lvorbisfile",
                "-lvorbis",
                "-logg",
                "-lbcrypt",

                "-static-libgcc",
                "-static-libstdc++"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
